default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight (called by GitHub Actions)"
  lane :beta do
    # 1. Unlock a temporary keychain on the runner.
    setup_ci

    # 2. Build a fastlane App Store Connect API key object. ALL the actions
    #    below (match, latest_testflight_build_number, upload_to_testflight)
    #    accept this and auth via the API key instead of an Apple ID password.
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_FILEPATH"],
      in_house: false
    )

    # 3. Pull (or generate on first run) the App Store distribution cert
    #    and provisioning profile from the match repo. The api_key is the
    #    fix for the "Missing username, non-interactive shell" failure —
    #    without it match tries to log in with Apple ID + password.
    match(
      type: "appstore",
      app_identifier: ENV["BUNDLE_ID"],
      team_id: ENV["APPLE_TEAM_ID"],
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )

    # 4. Set the build number to (latest TestFlight build) + 1.
    next_build = latest_testflight_build_number(
      app_identifier: ENV["BUNDLE_ID"],
      api_key: api_key,
      initial_build_number: 0
    ) + 1
    UI.message("Setting build number to #{next_build}")

    increment_build_number(
      build_number: next_build.to_s,
      xcodeproj: ENV["XCODE_PROJECT"]
    )

    # 5. Lock the team in the Xcode project (Godot writes it as a literal).
    update_project_team(
      path: ENV["XCODE_PROJECT"],
      teamid: ENV["APPLE_TEAM_ID"]
    )

    # 5b. Switch the project to MANUAL signing with our Distribution cert and
    #     match-managed provisioning profile. Godot's exported project defaults
    #     to automatic signing, which conflicts with the manual profile match
    #     installs — Xcode's auto-signer refuses to coexist with a manually
    #     specified Apple Distribution identity.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: ENV["XCODE_PROJECT"],
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: ENV["BUNDLE_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{ENV['BUNDLE_ID']}",
      targets: ["SmashBreaker"]
    )

    # 6. Build + sign.
    build_app(
      project: ENV["XCODE_PROJECT"],
      scheme: "SmashBreaker",
      configuration: "Release",
      export_method: "app-store",
      output_directory: ENV["IPA_OUTPUT_DIR"],
      output_name: "SmashBreaker.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          ENV["BUNDLE_ID"] => "match AppStore #{ENV['BUNDLE_ID']}"
        }
      }
    )

    # 7. Upload to TestFlight.
    upload_to_testflight(
      ipa: "#{ENV['IPA_OUTPUT_DIR']}/SmashBreaker.ipa",
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      changelog: "Automated CI build #{next_build}"
    )
  end
end
