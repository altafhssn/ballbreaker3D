# Force LF on files the Mac will execute or that engines parse strictly.
*.sh           text eol=lf
*.plist        text eol=lf
*.gd           text eol=lf
*.gdshader     text eol=lf
*.tscn         text eol=lf
*.tres         text eol=lf
*.cfg          text eol=lf
*.godot        text eol=lf

# Treat binaries as binary so Git doesn't try line-ending magic on them.
*.png          binary
*.svg          binary
*.wav          binary
*.ttf          binary
*.aab          binary
*.apk          binary
*.keystore     binary
*.p8           binary
